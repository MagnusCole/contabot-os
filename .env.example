# ============================================================
# ContaBot — Variables de entorno
# Copiar este archivo a .env y ajustar los valores
# ============================================================

# --- Base de datos ---
# Ruta al archivo SQLite (se crea automaticamente)
DATABASE_PATH=data/db/contabot.db

# --- IA (opcional) ---
# API key de xAI para funciones de inteligencia artificial
# (reconocimiento de boletas por foto, sugerencias, etc.)
# Si no se configura, las funciones de IA se desactivan.
XAI_API_KEY=

# --- WhatsApp (WAHA) ---
# URL del servidor WAHA (gateway de WhatsApp)
WAHA_URL=http://localhost:3000
# Nombre de la sesion de WAHA
WAHA_SESSION=default

# --- Bot ---
# Nombre de la empresa que aparece en mensajes del bot
BOT_COMPANY_NAME=Mi Empresa
# Contacto para escalamiento cuando el bot no puede resolver
ESCALATION_CONTACT=soporte
# Numero de telefono del bot (formato internacional, ej: 51999999999)
BOT_PHONE=

# --- Logging ---
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
